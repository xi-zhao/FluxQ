# Host and port for the thin HTTP gateway.
FLUXQ_GATEWAY_HOST=127.0.0.1
FLUXQ_GATEWAY_PORT=8787

# Shared secret used for the HMAC envelope:
# X-FluxQ-Timestamp + "\n" + X-FluxQ-Nonce + "\n" + raw_body
FLUXQ_GATEWAY_SHARED_SECRET=replace-with-random-secret

# Server-side allowlist and replay cache paths.
FLUXQ_WECHAT_ALLOWLIST_FILE=/srv/fluxq/gateway/allowlist.json
FLUXQ_GATEWAY_STATE_ROOT=/srv/fluxq/gateway/state

# Parent directory for per-user workspaces. The gateway appends:
# <workspace_key>/.quantum
FLUXQ_GATEWAY_WORKSPACES_ROOT=/srv/fluxq/workspaces

# Header names expected from the cc-connect claw adapter.
FLUXQ_GATEWAY_TIMESTAMP_HEADER=X-FluxQ-Timestamp
FLUXQ_GATEWAY_NONCE_HEADER=X-FluxQ-Nonce
FLUXQ_GATEWAY_SIGNATURE_HEADER=X-FluxQ-Signature
