        consequence="Compares trusted FluxQ runtime inputs and policy outcomes.",
    ),
    "doctor": CommandSpec(
        tokens=("doctor",),
        allowed_options=("fix", "ci"),
        machine_outputs=("json", "jsonl"),
        consequence="Checks workspace and environment health for the selected FluxQ workspace.",
