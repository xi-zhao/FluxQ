    "backend list": CommandSpec(
        tokens=("backend", "list"),
        allowed_options=(),
        consequence="Lists available runtime backends and readiness information.",
    ),
    "ibm configure": CommandSpec(
        tokens=("ibm", "configure"),
        allowed_options=("credential_mode", "instance", "token_env", "saved_account_name"),
        consequence="Configures IBM credential references for the selected FluxQ workspace.",
    ),
    "bench": CommandSpec(
        tokens=("bench",),
        allowed_options=(
            "backends",
            "report_file",
            "revision",
            "baseline",
            "require_comparable",
            "forbid_status_regressions",
            "max_width_regression",
            "max_depth_regression",
            "max_two_qubit_regression",
            "max_measure_regression",
        ),
        machine_outputs=("json", "jsonl"),
        consequence="Runs structural backend benchmarks on the selected FluxQ workload.",
    ),
    "export": CommandSpec(
        tokens=("export",),
        allowed_options=("format", "profile", "report_file", "revision"),
        consequence="Exports one artifact from the current FluxQ runtime object.",
