#!/usr/bin/env python3
"""Shipped-surface FluxQ tool router for the cc-connect claw integration."""

from __future__ import annotations

import argparse
import hashlib
import json
import re
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Callable, Mapping, Sequence


SAFE_OPTION_PATTERN = re.compile(r"^[a-z][a-z0-9_]*$")
SHELL_FRAGMENT_PATTERN = re.compile(r"[;&|`<>]|\$\(|\n")


Runner = Callable[..., subprocess.CompletedProcess[str]]


@dataclass(frozen=True)
class CommandSpec:
    """Approved `qrun` command family metadata."""

    tokens: tuple[str, ...]
    allowed_options: tuple[str, ...] = ()
    bool_flags: dict[str, tuple[str | None, str | None]] = field(default_factory=dict)
    positional_arg_count: int = 0
    requires_workspace: bool = True
    machine_outputs: tuple[str, ...] = ("json",)
    may_create_remote_job: bool = False
    may_spend: bool = False
    consequence: str = "Runs the shipped FluxQ control-plane command without bypassing qrun."


APPROVED_COMMANDS: dict[str, CommandSpec] = {
    "init": CommandSpec(tokens=("init",), consequence="Initializes the selected FluxQ workspace."),
    "prompt": CommandSpec(
        tokens=("prompt",),
        positional_arg_count=1,
        requires_workspace=False,
        consequence="Normalizes a natural-language request without mutating the workspace.",
    ),
    "resolve": CommandSpec(
        tokens=("resolve",),
        allowed_options=("intent_file", "intent_json_file", "qspec_file", "report_file", "revision", "intent_text"),
        consequence="Resolves ingress into canonical FluxQ runtime objects.",
    ),
    "plan": CommandSpec(
        tokens=("plan",),
        allowed_options=("intent_file", "intent_json_file", "qspec_file", "report_file", "revision", "intent_text"),
        consequence="Builds a dry-run execution plan for the selected FluxQ input.",
    ),
    "status": CommandSpec(tokens=("status",), allowed_options=(), consequence="Returns the thin workspace status summary."),
    "show": CommandSpec(
        tokens=("show",),
        allowed_options=("revision", "latest"),
        bool_flags={"latest": ("--latest", "--no-latest")},
        consequence="Shows the current or requested FluxQ revision.",
