#!/usr/bin/env python3
"""Executable shim for the local `lark-cli` polling bridge."""

from __future__ import annotations

import importlib.util
import sys
from pathlib import Path
from typing import Any


BRIDGE_PATH = Path(__file__).resolve().parents[1] / "lark_cli_bridge.py"


def _load_bridge_module() -> Any:
    spec = importlib.util.spec_from_file_location("fluxq_lark_cli_bridge", BRIDGE_PATH)
    assert spec is not None
    assert spec.loader is not None
    module = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = module
    spec.loader.exec_module(module)
    return module


def main() -> None:
    """Run the bridge CLI from the adjacent integration module."""

    module = _load_bridge_module()
    module.main()


if __name__ == "__main__":
    main()
